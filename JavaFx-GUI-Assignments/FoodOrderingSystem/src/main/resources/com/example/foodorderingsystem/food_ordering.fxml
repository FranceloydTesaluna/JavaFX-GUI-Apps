<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox alignment="CENTER" spacing="20" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.foodorderingsystem.FoodController"
      prefHeight="350.0" prefWidth="450.0">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <HBox spacing="50" alignment="CENTER">

        <VBox spacing="10" alignment="TOP_CENTER">
            <Label text="Foods"/>
            <GridPane hgap="20" vgap="10">
                <CheckBox fx:id="cPizza" text="Pizza" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                <Label text="Php 100" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                <CheckBox fx:id="cBurger" text="Burger" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                <Label text="Php 80" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                <CheckBox fx:id="cFries" text="Fries" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                <Label text="Php 65" GridPane.columnIndex="1" GridPane.rowIndex="2"/>

                <CheckBox fx:id="cSoftDrinks" text="Soft Drinks" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                <Label text="Php 55" GridPane.columnIndex="1" GridPane.rowIndex="3"/>

                <CheckBox fx:id="cTea" text="Tea" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
                <Label text="Php 50" GridPane.columnIndex="1" GridPane.rowIndex="4"/>

                <CheckBox fx:id="cSundae" text="Sundae" GridPane.columnIndex="0" GridPane.rowIndex="5"/>
                <Label text="Php 40" GridPane.columnIndex="1" GridPane.rowIndex="5"/>
            </GridPane>
        </VBox>

        <VBox spacing="10" alignment="TOP_LEFT">
            <Label text="Discounts"/>

            <fx:define>
                <ToggleGroup fx:id="discountGroup"/>
            </fx:define>

            <RadioButton fx:id="rbNone" text="None" toggleGroup="$discountGroup" selected="true"/>
            <RadioButton fx:id="rb5" text="5% Off" toggleGroup="$discountGroup"/>
            <RadioButton fx:id="rb10" text="10% Off" toggleGroup="$discountGroup"/>
            <RadioButton fx:id="rb15" text="15% Off" toggleGroup="$discountGroup"/>
        </VBox>
    </HBox>

    <Button fx:id="btnOrder" text="Order" onAction="#handleOrder"
            prefWidth="100" prefHeight="30"/>

</VBox>
