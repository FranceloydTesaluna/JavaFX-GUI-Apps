<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER" spacing="15"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.numbercounter.NumberCounterController">

    <Label fx:id="countLabel" text="0" />

    <HBox alignment="CENTER" spacing="10">
        <Button fx:id="decreaseButton" text="Decrease" onAction="#handleDecrease"/>
        <Button fx:id="increaseButton" text="Increase" onAction="#handleIncrease"/>
    </HBox>

</VBox>